# ============================================================
# PulseTrack Backend — .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Required: Supabase connection ---
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# --- Optional: Admin operations (bypasses RLS) ---
# Required if you use any admin-only endpoints.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY="your-service-role-key-here"

# --- Optional: JWT verification (production-recommended) ---
# Enables offline, fast JWT decoding without calling Supabase API on every request.
# Get from: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET="your-jwt-secret-here"

# --- Server configuration ---
BACKEND_PORT=8000

# --- CORS: Allowed frontend origins (comma-separated, no trailing slash) ---
# Development:
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173"
# Production example:
# ALLOWED_ORIGINS="https://your-app.com,https://www.your-app.com"
