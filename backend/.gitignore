# ============================================================
# PulseTrack Backend — .gitignore
# ============================================================

# Environment files (contains secrets — NEVER commit)
.env
.env.*
!.env.example

# Virtual environments
venv/
.venv/
env/
ENV/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/

# Testing
.pytest_cache/
htmlcov/
.coverage
*.cover

# Type checking
.mypy_cache/
.dmypy.json

# IDE
.idea/
.vscode/
*.suo
*.user
