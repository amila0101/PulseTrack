# ============================================================
# PulseTrack Frontend — .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
#
# Vite ONLY exposes variables prefixed with VITE_ to the browser bundle.
# ============================================================

# --- Required: Supabase connection ---
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# --- Required: FastAPI backend base URL ---
# Development (direct):      http://localhost:8000
# Development (Vite proxy):  (leave empty — proxy handles /api/* routing)
# Production:                https://api.your-app.com
VITE_API_BASE_URL="http://localhost:8000"
